DATABASE_URL=postgresql://localhost/deucelocal
SESSION_SECRET=
NODE_ENV=development
PORT=5001

# Clerk auth — leave blank/commented to use dev username auth
# CLERK_SECRET_KEY=your_clerk_secret_key_here
# VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
# CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here
# Clerk Billing — configure plans in Clerk Dashboard (Billing section)
# Stripe handles payment processing automatically via Clerk Billing

# Sentry error tracking (optional — leave blank to disable)
SENTRY_DSN=

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@deucediary.com

# Admin dashboard key
# ADMIN_KEY=your_admin_key_here
